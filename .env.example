# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# SECRET_KEY is required — the app will not start without it.
# Generate one with:  python -c "import secrets; print(secrets.token_hex(32))" or you can make one up yourself or just leave as is

SECRET_KEY=replace-with-a-random-secret-key

DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=HandyBridge

# Optional — leave blank for local development
# FLASK_ENV=production   # enables HTTPS-only cookies and forced HTTPS
# FLASK_DEBUG=1          # enables Flask debug mode (never set in production)
